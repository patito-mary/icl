    "from scipy.stats import binned_statistic_2d\n",
    "\n",
    "r_plot  = R200c[i_demo]\n",
    "n_pix   = 512\n",
    "edges   = np.linspace(-r_plot, r_plot, n_pix + 1)\n",
    "pix_pc2 = ((2 * r_plot / n_pix) * 1e3)**2\n",
    "\n",
    "H, _, _, _ = binned_statistic_2d(pos_rot[:, 0], pos_rot[:, 1],\n",
    "                                   lum_b, statistic='sum',\n",
    "                                   bins=[edges, edges])\n",
    "\n",
